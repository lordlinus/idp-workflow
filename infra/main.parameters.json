{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentParameters.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "environmentName": {
      "value": "${AZURE_ENV_NAME}"
    },
    "location": {
      "value": "${AZURE_LOCATION}"
    },
    "staticWebAppLocation": {
      "value": "${AZURE_SWA_LOCATION}"
    },
    "azureSignalRConnectionString": {
      "value": "${AZURE_SIGNALR_CONNECTION_STRING}"
    },
    "azureDocumentIntelligenceEndpoint": {
      "value": "${AZURE_DOCUMENT_INTELLIGENCE_ENDPOINT}"
    },
    "azureDocumentIntelligenceKey": {
      "value": "${AZURE_DOCUMENT_INTELLIGENCE_KEY}"
    },
    "cognitiveServicesEndpoint": {
      "value": "${COGNITIVE_SERVICES_ENDPOINT}"
    },
    "cognitiveServicesKey": {
      "value": "${COGNITIVE_SERVICES_KEY}"
    },
    "azureOpenAIEndpoint": {
      "value": "${AZURE_OPENAI_ENDPOINT}"
    },
    "azureOpenAIKey": {
      "value": "${AZURE_OPENAI_KEY}"
    },
    "azureOpenAIChatDeploymentName": {
      "value": "${AZURE_OPENAI_CHAT_DEPLOYMENT_NAME}"
    },
    "azureOpenAIReasoningDeploymentName": {
      "value": "${AZURE_OPENAI_REASONING_DEPLOYMENT_NAME}"
    },
    "azureOpenAIApiVersion": {
      "value": "${AZURE_OPENAI_API_VERSION}"
    },
    "taskHubName": {
      "value": "${TASKHUB_NAME}"
    },
    "principalId": {
      "value": "${AZURE_PRINCIPAL_ID}"
    }
  }
}
