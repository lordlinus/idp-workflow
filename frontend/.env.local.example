# =============================================================================
# IDP Workflow — Frontend Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in your values.
# Variables prefixed with NEXT_PUBLIC_ are exposed to the browser.
# =============================================================================

# Base URL of the Azure Functions backend (no trailing /api).
# For local development, use http://localhost:7071.
# For production, use the deployed Azure Functions URL.
NEXT_PUBLIC_API_BASE_URL=http://localhost:7071
