# =============================================================================
# IDP Workflow — Frontend Environment Variables
# =============================================================================
# Copy this file to .env.development (loaded only during `next dev`).
# Variables prefixed with NEXT_PUBLIC_ are exposed to the browser.
# Production values are in .env.production (loaded during `next build`).
# =============================================================================

# Base URL of the Azure Functions backend.
# For local development, use http://localhost:7071/api.
# For production (SWA linked backend), /api is set in .env.production.
NEXT_PUBLIC_API_BASE_URL=http://localhost:7071/api
